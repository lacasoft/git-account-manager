#!/usr/bin/env bash

# Git Account Manager (GAM) - CLI para gestionar múltiples cuentas de GitHub
# Version: 1.0.0
# Author: lacasoft

set -e

# Directorio base: ~/.gam si está instalado, directorio del script en modo dev
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -d "$HOME/.gam/lib" ]; then
    GAM_HOME="$HOME/.gam"
else
    GAM_HOME="$SCRIPT_DIR"
fi
LIB_DIR="$GAM_HOME/lib"
export TEMPLATES_DIR="$GAM_HOME/templates"

# Colores
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
BLUE=$'\033[0;34m'
MAGENTA=$'\033[0;35m'
CYAN=$'\033[0;36m'
NC=$'\033[0m'

# Cargar librerías
source "$LIB_DIR/utils.sh"
source "$LIB_DIR/ssh.sh"
source "$LIB_DIR/account.sh"
source "$LIB_DIR/git-config.sh"

# Mostrar ayuda
show_help() {
    cat << EOF

${BLUE}  ██████╗  █████╗ ███╗   ███╗${NC}
${BLUE} ██╔════╝ ██╔══██╗████╗ ████║${NC}
${BLUE} ██║  ███╗███████║██╔████╔██║${NC}
${BLUE} ██║   ██║██╔══██║██║╚██╔╝██║${NC}
${BLUE} ╚██████╔╝██║  ██║██║ ╚═╝ ██║${NC}
${BLUE}  ╚═════╝ ╚═╝  ╚═╝╚═╝     ╚═╝${NC}
${CYAN}  Git Account Manager — v1.0.0${NC}

${BLUE}┌─────────────────────────────────────────────────────┐${NC}
${BLUE}│${NC}  ${GREEN}USO${NC}  ${BLUE}│${NC}  gam <comando> [opciones]                      ${BLUE}│${NC}
${BLUE}└─────────────────────────────────────────────────────┘${NC}

${CYAN}COMANDOS${NC}
  ${YELLOW}add${NC}     [--name X --email X --username X]   ➕  Agregar cuenta
  ${YELLOW}list${NC}                                        📋  Listar cuentas
  ${YELLOW}remove${NC}  <cuenta>                            🗑️   Eliminar cuenta
  ${YELLOW}test${NC}    [cuenta]                            🔌  Probar conexión SSH
  ${YELLOW}clone${NC}   <cuenta> <usuario/repo> [destino]  📥  Clonar repositorio
  ${YELLOW}switch${NC}  <cuenta>                            🔄  Cambiar config Git global
  ${YELLOW}use${NC}     <carpeta>                           📂  Git automático por carpeta
  ${YELLOW}export${NC}                                      💾  Exportar configuración
  ${YELLOW}import${NC}  <archivo>                           📤  Importar configuración
  ${YELLOW}help${NC}                                        ❓  Mostrar esta ayuda

${CYAN}EJEMPLOS${NC}
  gam add                                         ${BLUE}# interactivo${NC}
  gam add --name personal --email yo@mail.com --username miuser
  gam list
  gam test personal
  gam clone personal lacasoft/mi-repo
  gam use ~/code/trabajo
  gam switch trabajo
  gam export > backup-gam-\$(date +%Y%m%d).txt

${BLUE}──────────────────────────────────────────────────────${NC}
${CYAN}  🌐  https://github.com/lacasoft/git-account-manager${NC}
${BLUE}──────────────────────────────────────────────────────${NC}

EOF
}

# Comando principal
main() {
    local cmd="${1:-help}"
    shift || true
    
    case "$cmd" in
        add)
            add_account "$@"
            ;;
        list)
            list_accounts
            ;;
        remove)
            remove_account "$@"
            ;;
        test)
            test_connection "$@"
            ;;
        clone)
            clone_repo "$@"
            ;;
        switch)
            switch_git_config "$@"
            ;;
        use)
            setup_auto_git_config "$@"
            ;;
        export)
            export_config
            ;;
        import)
            import_config "$@"
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            echo -e "${RED}Error: Comando desconocido '$cmd'${NC}"
            echo "Ejecuta 'gam help' para ver los comandos disponibles"
            exit 1
            ;;
    esac
}

# Ejecutar
main "$@"